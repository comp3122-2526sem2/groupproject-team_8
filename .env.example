# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SECRET_KEY=
# Legacy key names (optional backward compatibility)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=
OPENROUTER_MODEL=
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
OPENROUTER_BASE_URL=

# Optional Python backend adapter (strangler path)
PYTHON_BACKEND_ENABLED=false
PYTHON_BACKEND_BLUEPRINT_ENABLED=false
PYTHON_BACKEND_QUIZ_ENABLED=false
PYTHON_BACKEND_FLASHCARDS_ENABLED=false
PYTHON_BACKEND_CHAT_ENABLED=false
PYTHON_BACKEND_CHAT_ENGINE=direct_v1
PYTHON_BACKEND_CHAT_TOOL_MODE=off
PYTHON_BACKEND_CHAT_TOOL_CATALOG=grounding_context.read
PYTHON_BACKEND_STRICT=false
PYTHON_BACKEND_URL=http://localhost:8001
PYTHON_BACKEND_API_KEY=
PYTHON_BACKEND_LOG_PROVIDER_FAILURES=true
PYTHON_BACKEND_MATERIAL_TIMEOUT_MS=15000

# Defaults
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000
BLUEPRINT_TOTAL_TIMEOUT_MS=120000
EMBEDDING_DIM=1536
CHUNK_TOKENS=1000
# Overlap token budget; translated to word overlap using token estimation.
CHUNK_OVERLAP=100

# Background job auth (required for /api/materials/process protection)
CRON_SECRET=

# Job execution backend: `supabase` (default), `python` (web -> python -> supabase worker), or `legacy` (Next.js route worker)
MATERIAL_WORKER_BACKEND=supabase

# Background job retry limits
MATERIAL_JOB_MAX_ATTEMPTS=5

# Supabase queue worker tuning
MATERIAL_WORKER_BATCH=3
MATERIAL_JOB_VISIBILITY_TIMEOUT_SECONDS=300
MATERIAL_JOB_LOCK_MINUTES=15
PDF_TEXT_PAGE_LIMIT=40
