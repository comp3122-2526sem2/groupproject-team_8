# Repo-wide environment reference only.
# This file is not auto-loaded by pnpm, uvicorn, or Playwright in this repo.
# Use the surface-specific examples for actual runtime files:
#   - web/.env.example -> web/.env.local
#   - backend/.env.example -> export into your shell or use your env loader
#   - tests/.env.example -> tests/.env
# Keep Supabase Edge Function worker secrets in Supabase, not in web/.env.local.

# Web runtime (copy to web/.env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SECRET_KEY=
# Optional legacy compatibility names used by existing code paths.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GUEST_MODE_ENABLED=false

# Shared AI provider configuration
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000

# Web + backend prompt and retrieval tuning
BLUEPRINT_TOTAL_TIMEOUT_MS=120000
BLUEPRINT_SCHEMA_VERSION=v2
AI_PROMPT_QUALITY_PROFILE=quality_v1
AI_GROUNDING_MODE=balanced
CHUNK_TOKENS=1000
# Overlap token budget; translated to word overlap using token estimation.
CHUNK_OVERLAP=100
CHAT_CONTEXT_RECENT_TURNS=12
CHAT_COMPACTION_TRIGGER_TURNS=30
CHAT_COMPACTION_MIN_NEW_TURNS=6
CHAT_CONTEXT_WINDOW_TOKENS=12000
CHAT_OUTPUT_TOKEN_RESERVE=1400
CHAT_GENERATION_MAX_TOKENS=9000
CHAT_COMPACTION_CONTEXT_PRESSURE=0.8
RAG_CONTEXT_TOKENS=24000
RAG_MATCH_COUNT=24
RAG_MAX_PER_MATERIAL=6

# Python backend
PYTHON_BACKEND_URL=http://localhost:8001
PYTHON_BACKEND_API_KEY=
# Local-only escape hatch. Keep false in hosted environments.
PYTHON_BACKEND_ALLOW_UNAUTHENTICATED_REQUESTS=false
PYTHON_BACKEND_LOG_PROVIDER_FAILURES=true
PYTHON_BACKEND_CHAT_ENGINE=direct_v1
PYTHON_BACKEND_CHAT_TOOL_MODE=off
PYTHON_BACKEND_CHAT_TOOL_CATALOG=grounding_context.read,memory.search,memory.save
PYTHON_BACKEND_MATERIAL_TIMEOUT_MS=15000
PYTHON_BACKEND_CHAT_TIMEOUT_MS=45000

# Backend-only guest guardrails
GUEST_MAX_CONCURRENT_AI_REQUESTS=20
GUEST_CHAT_LIMIT=50
GUEST_QUIZ_LIMIT=10
GUEST_FLASHCARDS_LIMIT=10
GUEST_BLUEPRINT_LIMIT=5
GUEST_EMBEDDING_LIMIT=15

# Material worker / Supabase Edge Function secrets
# Configure these in Supabase Edge Function secrets for hosted worker execution.
MATERIAL_WORKER_TOKEN=
# Leave blank to let the backend derive the canonical worker URL from SUPABASE_URL.
MATERIAL_WORKER_FUNCTION_URL=
MATERIAL_WORKER_BATCH=3
MATERIAL_JOB_MAX_ATTEMPTS=5
MATERIAL_JOB_VISIBILITY_TIMEOUT_SECONDS=300
MATERIAL_JOB_LOCK_MINUTES=15
PDF_TEXT_PAGE_LIMIT=40
EMBEDDING_DIM=1536
