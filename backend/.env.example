# Reference checklist for the standalone Python backend.
# This file is not auto-loaded by the documented uvicorn command.
# Export these variables into your shell or use your own env loader.

# Python backend auth
PYTHON_BACKEND_API_KEY=
# Local-only escape hatch. Keep false in hosted environments.
PYTHON_BACKEND_ALLOW_UNAUTHENTICATED_REQUESTS=false
PYTHON_BACKEND_LOG_PROVIDER_FAILURES=true

# AI provider routing
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=

# Supabase integration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional compatibility fallback names for shared or legacy deployments only.
# Prefer SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY above for new setups.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Supabase material worker integration
MATERIAL_WORKER_TOKEN=
MATERIAL_WORKER_BATCH=3
# Leave blank to let the backend derive the canonical worker URL from SUPABASE_URL.
MATERIAL_WORKER_FUNCTION_URL=

# Guest mode guardrails
GUEST_MAX_CONCURRENT_AI_REQUESTS=20
GUEST_CHAT_LIMIT=50
GUEST_QUIZ_LIMIT=10
GUEST_FLASHCARDS_LIMIT=10
GUEST_BLUEPRINT_LIMIT=5
GUEST_EMBEDDING_LIMIT=15
