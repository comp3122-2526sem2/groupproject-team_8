# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SECRET_KEY=

# Legacy key names (optional backward compatibility)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider hints (web reads these to pass provider order to Python backend)
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# AI and blueprint defaults
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000
BLUEPRINT_TOTAL_TIMEOUT_MS=120000
BLUEPRINT_SCHEMA_VERSION=v2
AI_PROMPT_QUALITY_PROFILE=quality_v1
AI_GROUNDING_MODE=balanced
CHUNK_TOKENS=1000
# Overlap token budget; translated to word overlap using token estimation.
CHUNK_OVERLAP=100
CHAT_CONTEXT_RECENT_TURNS=12
CHAT_COMPACTION_TRIGGER_TURNS=30
CHAT_COMPACTION_MIN_NEW_TURNS=6
CHAT_CONTEXT_WINDOW_TOKENS=12000
CHAT_OUTPUT_TOKEN_RESERVE=1400

# Python backend (required — all AI generation routes through this service)
# PYTHON_BACKEND_URL is required; the app will throw at call-time if it is not set.
PYTHON_BACKEND_CHAT_ENGINE=direct_v1
PYTHON_BACKEND_CHAT_TOOL_MODE=off
PYTHON_BACKEND_CHAT_TOOL_CATALOG=grounding_context.read,memory.search,memory.save
PYTHON_BACKEND_URL=http://localhost:8001
PYTHON_BACKEND_API_KEY=
PYTHON_BACKEND_MATERIAL_TIMEOUT_MS=15000
PYTHON_BACKEND_CHAT_TIMEOUT_MS=45000

# Material processing API tuning
MATERIAL_WORKER_BATCH=3

# Guest mode
NEXT_PUBLIC_GUEST_MODE_ENABLED=false

# AI generation tuning (optional — defaults shown)
CHAT_GENERATION_MAX_TOKENS=1400
CHAT_COMPACTION_CONTEXT_PRESSURE=0.75
RAG_CONTEXT_TOKENS=3000
RAG_MATCH_COUNT=12
RAG_MAX_PER_MATERIAL=4
