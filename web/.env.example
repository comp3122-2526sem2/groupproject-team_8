# Copy to web/.env.local.
# Hosted deployments must also set these in the web project's environment vars.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SITE_URL must be set explicitly for hosted auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-only key used by admin server actions in the web app.
SUPABASE_SECRET_KEY=

# Optional legacy compatibility names. Prefer the modern vars above for new setups.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider hints.
# The web app uses these only to hint provider order when delegating to the Python backend.
# If they are omitted, the backend's own provider configuration decides routing.
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# AI and blueprint defaults
AI_PROVIDER_DEFAULT=openrouter
AI_REQUEST_TIMEOUT_MS=30000
AI_EMBEDDING_TIMEOUT_MS=30000
BLUEPRINT_TOTAL_TIMEOUT_MS=120000
BLUEPRINT_SCHEMA_VERSION=v2
AI_PROMPT_QUALITY_PROFILE=quality_v1
AI_GROUNDING_MODE=balanced
CHUNK_TOKENS=1000
# Overlap token budget; translated to word overlap using token estimation.
CHUNK_OVERLAP=100
CHAT_CONTEXT_RECENT_TURNS=12
CHAT_COMPACTION_TRIGGER_TURNS=30
CHAT_COMPACTION_MIN_NEW_TURNS=6
CHAT_CONTEXT_WINDOW_TOKENS=12000
CHAT_OUTPUT_TOKEN_RESERVE=1400
CHAT_GENERATION_MAX_TOKENS=9000
CHAT_COMPACTION_CONTEXT_PRESSURE=0.8
RAG_CONTEXT_TOKENS=24000
RAG_MATCH_COUNT=24
RAG_MAX_PER_MATERIAL=6

# Python backend (required — all AI generation routes through this service)
# PYTHON_BACKEND_URL must be set explicitly in every environment.
PYTHON_BACKEND_CHAT_ENGINE=direct_v1
PYTHON_BACKEND_CHAT_TOOL_MODE=off
PYTHON_BACKEND_CHAT_TOOL_CATALOG=grounding_context.read,memory.search,memory.save
PYTHON_BACKEND_URL=http://localhost:8001
# Must match backend/.env.example when backend service auth is enabled.
PYTHON_BACKEND_API_KEY=
PYTHON_BACKEND_MATERIAL_TIMEOUT_MS=15000
PYTHON_BACKEND_CHAT_TIMEOUT_MS=45000

# Material processing API tuning
MATERIAL_WORKER_BATCH=3

# Guest mode
NEXT_PUBLIC_GUEST_MODE_ENABLED=false
